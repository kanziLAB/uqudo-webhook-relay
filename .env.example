# Copy to .env and fill in. Nothing here is committed with real values.

# -- Intuition target (REQUIRED) ----------------------------------------------
INTUITION_BASE_URL=https://<your-tenant>-data.env.intuitioncloud.io
INTUITION_TENANT_ID=<tenant-guid>
INTUITION_DATASET_ID=<uqudo-kyc-data-dataset-guid>
INTUITION_RUN_STRATEGY=true
# INTUITION_TOKEN=            # only if the Data API is locked down to bearer auth

# -- Uqudo JWS verification ----------------------------------------------------
# Verify the jwsResult signature against Uqudo's public key (get it via support).
# UQUDO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# With no key set, the relay refuses to forward unless you explicitly allow it:
ALLOW_UNVERIFIED=false

# -- Inbound auth (pick one; both work) ---------------------------------------
# 1) Custom header: portal sends this header, relay checks it.
WEBHOOK_AUTH_HEADER=x-api-key
WEBHOOK_AUTH_VALUE=<long-random-secret>
# 2) Capability URL: secret in the path, portal auth = None.
#    Endpoint becomes /api/uqudo-webhook/<token>.
# WEBHOOK_URL_TOKEN=<long-random-token>

# -- Delivery log backend ------------------------------------------------------
# memory | postgres | mongo | elasticsearch. If LOG_STORE is unset it is inferred
# from whichever connection URL is present below.
LOG_STORE=postgres
#   Postgres (Vercel/Neon inject POSTGRES_URL automatically):
DATABASE_URL=postgres://user:pass@host:5432/db
PG_SSL=true
#   MongoDB:
# MONGO_URL=mongodb://user:pass@host:27017/relay
#   Elasticsearch:
# ELASTICSEARCH_URL=https://host:9200
# ELASTICSEARCH_API_KEY=<base64-api-key>
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=<password>
LOG_TABLE=webhook_deliveries
# Capture the decoded JWT + mapped doc (masked) for debugging. OFF by default.
LOG_PAYLOADS=false

# -- Admin dashboard (unset ADMIN_PASSWORD => dashboard disabled) --------------
ADMIN_PASSWORD=<dashboard-password>
ADMIN_SESSION_SECRET=<long-random-string>   # required for multi-replica HA

# -- Client identity stamped on every forwarded document ----------------------
CLIENT_ID=your-client-id
CLIENT_NAME=Your Client Name

# -- docker-compose only -------------------------------------------------------
PORT=8080
POSTGRES_USER=relay
POSTGRES_PASSWORD=<db-password>
POSTGRES_DB=relay
RELAY_REPLICAS=3
